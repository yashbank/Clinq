# Local development: copy to `.env.local` (preferred) or `.env`.
# Never commit real secrets. Vercel: set the same keys under Project → Settings → Environment Variables.

# Site URL for auth email redirects (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase — Dashboard → Project Settings → API
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: server-only admin client (bypasses RLS). Do not expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI API — https://platform.openai.com/api-keys (server-only; do not use NEXT_PUBLIC_)
OPENAI_API_KEY=
