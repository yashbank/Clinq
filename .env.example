# Local development: copy to `.env.local` (preferred) or `.env`.
# Never commit real secrets. Vercel: set the same keys under Project → Settings → Environment Variables.

# Site URL for auth email links (no trailing slash). Match Supabase "Site URL".
# Local: http://localhost:3000 | Production: https://clinq-delta.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase — Dashboard → Project Settings → API
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: server-only admin client (bypasses RLS). Do not expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI API — https://platform.openai.com/api-keys (server-only; do not use NEXT_PUBLIC_)
OPENAI_API_KEY=

# Freelancer.com — https://developers.freelancer.com (OAuth app + REST). Server-only.
# Redirect URL must be registered exactly: {NEXT_PUBLIC_SITE_URL}/api/integrations/freelancer/callback
# SUPABASE_SERVICE_ROLE_KEY is required so OAuth tokens are stored outside browser-visible RLS.
# FREELANCER_CLIENT_ID=
# FREELANCER_CLIENT_SECRET=
# Optional overrides (defaults shown):
# FREELANCER_ACCOUNTS_BASE_URL=https://accounts.freelancer.com
# FREELANCER_API_BASE_URL=https://www.freelancer.com
